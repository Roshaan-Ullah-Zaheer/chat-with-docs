# ----------------------------------------------------------------------------
# DocChat — environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored, so your keys never get committed.
# ----------------------------------------------------------------------------

# Google Gemini API key(s), comma-separated (free, no credit card).
# Used for chat answers (flash -> flash-lite per key) AND embeddings.
# Add multiple keys from different accounts for more free-tier headroom.
# Get keys at: https://aistudio.google.com/apikey
GOOGLE_API_KEYS=key_one,key_two,key_three

# Groq API key — final fallback for chat answers when all Gemini keys are
# exhausted (free, no credit card, high limits). https://console.groq.com/keys
GROQ_API_KEY=

# Upstash Vector database (free tier).
# Create an index at: https://console.upstash.com/vector
#   - Dimensions: 768
#   - Distance metric: COSINE
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
