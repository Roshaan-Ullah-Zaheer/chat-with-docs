# ----------------------------------------------------------------------------
# DocChat — environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored, so your keys never get committed.
# ----------------------------------------------------------------------------

# Google Gemini API key (free, no credit card).
# Get one at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Upstash Vector database (free tier).
# Create an index at: https://console.upstash.com/vector
#   - Dimensions: 768
#   - Distance metric: COSINE
# Then copy the REST URL and REST token from the index's "Details" page.
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
